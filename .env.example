# Database
DATABASE_URL="mysql://root:root@localhost:3306/smartgrade"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# WeChat Mini Program
WECHAT_APPID="your-wechat-appid"
WECHAT_SECRET="your-wechat-secret"

# Upload
UPLOAD_DIR="./uploads"
UPLOAD_MAX_SIZE=10485760

# Server
PORT=3000
NODE_ENV=development

# API Prefix
API_PREFIX="/api/v1"