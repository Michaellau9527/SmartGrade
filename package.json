{
  "name": "smartgrade",
  "version": "1.0.0",
  "private": true,
  "description": "SmartGrade 智慧年级管理平台 - Monorepo",
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:miniapp": "pnpm --filter miniapp dev:weapp",
    "dev:admin": "pnpm --filter admin dev",
    "build:backend": "pnpm --filter backend build",
    "build:miniapp": "pnpm --filter miniapp build:weapp",
    "build:admin": "pnpm --filter admin build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "db:generate": "pnpm --filter backend prisma:generate",
    "db:push": "pnpm --filter backend prisma:push",
    "db:migrate": "pnpm --filter backend prisma:migrate",
    "db:studio": "pnpm --filter backend prisma:studio"
  },
  "keywords": [
    "smartgrade",
    "education",
    "school-management",
    "nestjs",
    "taro",
    "react"
  ],
  "author": "SmartGrade Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}